---
import BaseLayout from '../layouts/BaseLayout.astro';
import profileData from '../data/profile.json';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Modules
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import About from '../components/sections/About.astro';
import Experience from '../components/sections/Experience.astro';
import Skills from '../components/sections/Skills.astro';
import Projects from '../components/sections/Projects.astro';
import OtherProjects from '../components/sections/OtherProjects.astro';
import Education from '../components/sections/Education.astro';
import Contact from '../components/sections/Contact.astro';

import { TypingEffect } from '../components/ui/TypingEffect';
import { AnimatedSection } from '../components/ui/AnimatedSection';

const { name, tagline, roles, image } = profileData;
const title = `${name} — Fullstack Developer | Backend Specialist`;
const description = tagline;
---

<BaseLayout title={title} description={description}>
  <Header />
  
  <main class="mx-auto max-w-5xl px-6 md:px-12 pt-16 space-y-10">
    <!-- Hero Section -->
    <section id="hero" class="min-h-[90vh] flex flex-col justify-center py-20 relative">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-7 z-10">
          <AnimatedSection client:load>
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-accent-cyan/10 border border-accent-cyan/20 text-[10px] font-bold text-accent-cyan w-fit mb-8 shadow-glow-cyan uppercase tracking-[0.2em] glass">
              <span class="w-2 h-2 rounded-full bg-accent-cyan shadow-[0_0_10px_#22d3ee] animate-pulse"></span>
              {t("hero.available")}
            </div>
            
            <div class="space-y-2 mb-10">
              <p class="text-accent-indigo text-xl font-semibold tracking-wide opacity-90">{t("hero.greeting")} —</p>
              <h1 class="text-7xl md:text-9xl font-black tracking-tightest leading-[0.9] text-gradient py-2">
                {name}
              </h1>
              <div class="pt-4">
                <TypingEffect client:load words={roles} />
              </div>
            </div>
            
            <p class="text-muted-foreground text-lg md:text-xl max-w-xl mb-12 leading-relaxed font-medium">
              {tagline}
            </p>
            
            <div class="flex flex-wrap items-center gap-6">
              <a href="#projects" class="px-10 py-4.5 bg-primary text-primary-foreground font-black rounded-xl hover:scale-105 active:scale-95 transition-all shadow-glow-cyan relative group overflow-hidden">
                <span class="relative z-10">{t("hero.viewProjects")}</span>
                <div class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
              </a>
              <a href={t("cv.url")} target="_blank" class="px-10 py-4.5 border border-border-accent text-accent-cyan font-bold rounded-xl hover:bg-accent-cyan/10 transition-all hover:-translate-y-1 glass flex items-center gap-3 group">
                <span>{t("hero.downloadCV")}</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-download group-hover:translate-y-1 transition-transform"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
              </a>
            </div>
          </AnimatedSection>
        </div>
 
        <div class="lg:col-span-5 flex justify-center lg:justify-end">
          <AnimatedSection client:load delay={0.2}>
            <div class="relative w-72 h-72 md:w-96 md:h-96">
              <!-- Animated outer ring -->
              <div class="absolute inset-0 rounded-full border-2 border-dashed border-accent-cyan/30 animate-[spin_20s_linear_infinite]"></div>
              
              <!-- Glow behind photo -->
              <div class="absolute inset-4 bg-gradient-main rounded-full blur-3xl opacity-20 animate-pulse"></div>
              
              <!-- Photo Container -->
              <div class="relative w-full h-full rounded-2xl border border-border-accent/40 p-3 bg-bg-card/40 backdrop-blur-sm shadow-2xl overflow-hidden group">
                <div class="absolute inset-0 bg-gradient-to-tr from-accent-cyan/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                <img src={image} alt={name} class="w-full h-full object-cover rounded-xl transition-transform duration-500 group-hover:scale-110" />
              </div>
            </div>
          </AnimatedSection>
        </div>
      </div>
    </section>

    <!-- Content Sections -->
    <About />
    <Experience />
    <Skills />
    <Projects />
    <OtherProjects />
    <Education />
    <Contact />
    
  </main>
  
  <Footer />
</BaseLayout>
