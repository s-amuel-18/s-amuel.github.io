---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { useTranslations } from '../../i18n/utils';
import projectsData from '../../data/projects.json';
import { marked } from 'marked';

export function getStaticPaths() {
  const featuredProjects = projectsData.filter(p => p.featured !== false);
  return featuredProjects.map(project => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const lang = 'en';
const t = useTranslations(lang);
const contentHtml = marked.parse(project.content?.[lang] || '');
---

<BaseLayout title={`${project.title} - ${t("nav.projects")}`} description={project.description[lang]}>
  <Header />
  <main class="mx-auto max-w-5xl px-6 md:px-12 pt-32 pb-20" transition:animate="slide">
    <a href="/#projects" class="inline-flex items-center gap-2 text-muted-foreground hover:text-accent-cyan font-bold transition-colors mb-10">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      {t("projects.back")}
    </a>
    
    <article class="glass p-8 md:p-14 rounded-[3rem] relative overflow-hidden shadow-2xl">
      <!-- Decorative background -->
      <div class="absolute top-[-10%] right-[-10%] w-[50%] h-[50%] bg-accent-cyan/10 rounded-full blur-[100px] pointer-events-none"></div>
      
      <div class="flex flex-col lg:flex-row gap-12 items-start mb-16 relative z-10">
        <div class="w-full lg:w-1/2 relative group">
           <div class="absolute inset-0 bg-gradient-main rounded-[2rem] blur-xl opacity-20 group-hover:opacity-40 transition-opacity duration-500"></div>
           <img
             src={project.image}
             alt={project.title}
             transition:name={`project-img-${project.id}`}
             class="w-full relative rounded-[2rem] shadow-xl border border-white/5 object-cover h-64 md:h-[22rem]"
           />
        </div>
        
        <div class="space-y-6 lg:w-1/2">
            <h1 class="text-4xl md:text-5xl font-black text-foreground tracking-tight">{project.title}</h1>
            
            <p class="text-muted-foreground text-lg leading-relaxed">
              {project.description[lang]}
            </p>

            <div class="flex flex-wrap gap-2 pt-2">
                {project.tech.map(tech => (
                    <span class="px-3 py-1 bg-white/5 text-muted-foreground text-xs font-bold rounded-lg border border-white/5 uppercase tracking-wider">
                      {tech}
                    </span>
                ))}
            </div>

            <div class="flex flex-wrap gap-4 pt-6">
              {project.projectUrl && (
                  <a href={project.projectUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3.5 bg-primary text-primary-foreground font-bold rounded-xl hover:scale-105 active:scale-95 transition-all shadow-glow-cyan text-sm">
                      <span>{t("projects.openProject")}</span>
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
                  </a>
              )}
              {project.github && (
                  <a href={project.github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3.5 border border-border-accent text-accent-cyan font-bold rounded-xl hover:bg-white/5 transition-all text-sm">
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                      {t("projects.github")}
                  </a>
              )}
            </div>
        </div>
      </div>

      <div class="mt-8 pt-12 border-t border-border/40 relative z-10">
        <div class="prose prose-invert prose-lg max-w-none 
                    prose-headings:text-foreground prose-headings:font-bold prose-headings:tracking-tight 
                    prose-h2:text-3xl prose-h2:font-black prose-h2:border-b prose-h2:border-white/10 prose-h2:pb-4 prose-h2:mt-16 prose-h2:mb-8
                    prose-h3:text-2xl prose-h3:font-bold prose-h3:text-accent-cyan prose-h3:mt-10 prose-h3:mb-6
                    prose-p:text-muted-foreground prose-p:leading-relaxed prose-p:mb-6
                    prose-a:text-accent-cyan prose-a:no-underline hover:prose-a:underline hover:prose-a:text-accent-indigo prose-a:transition-colors
                    prose-strong:text-foreground prose-strong:font-bold prose-strong:bg-white/5 prose-strong:px-1.5 prose-strong:py-0.5 prose-strong:rounded-md
                    prose-ul:text-muted-foreground prose-ul:my-6 prose-ul:space-y-3 prose-li:marker:text-accent-cyan/80
                    prose-code:text-accent-indigo prose-code:bg-white/5 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-md prose-code:before:content-none prose-code:after:content-none
                    prose-blockquote:border-l-accent-cyan prose-blockquote:bg-white/5 prose-blockquote:py-2 prose-blockquote:px-6 prose-blockquote:rounded-r-2xl prose-blockquote:text-muted-foreground prose-blockquote:not-italic
                    glass p-8 md:p-12 rounded-[2.5rem] border-white/5 shadow-xl hover:shadow-glow-cyan transition-all duration-500">
          <div set:html={contentHtml} />
        </div>
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>
